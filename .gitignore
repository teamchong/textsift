node_modules/
dist/
zig-out/
zig-cache/
.zig-cache/
*.log
.DS_Store
*.wasm
!dist/*.wasm
.env
.env.local
test-results/
playwright-report/
coverage/
.claude/
__pycache__/
# Measurement artifacts (corpora, .npz binaries). Reproduction recipe
# lives in docs/stage3-gate-measurement.md.
data/
measurements/
tests/fixtures/pii-weights-full.bin
# SPIR-V artifacts — compiled at build time from src/native/vulkan/shaders/*.comp.glsl
packages/textsift/src/native/vulkan/shaders/*.spv
# Vendored Dawn artifacts — built per-platform in CI (release.yml + bench.yml)
# and downloaded into vendor/dawn/ at build time.
packages/textsift/vendor/dawn/lib/*.a
packages/textsift/vendor/dawn/lib/*.lib
packages/textsift/vendor/dawn/lib/*.dll
# CI bench summary output (uploaded as workflow artifact, aggregated
# across OS by scripts/bench-aggregate.mjs into the workflow summary).
bench-results.json
# Per-triple subpackage staging dir written by scripts/publish-natives.mjs.
# Contents are published to npm as @textsift/native-{linux-x64,...} and
# linked from the umbrella package's optionalDependencies.
dist-pkg/
