{
  "name": "textsift-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for textsift and textsift-core. Run `npm install` here to set up workspaces; per-package scripts live in packages/*/package.json.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs-site"
  ],
  "scripts": {
    "build": "npm run build -w textsift-core && npm run build -w textsift",
    "build:core": "npm run build -w textsift-core",
    "build:umbrella": "npm run build -w textsift",
    "typecheck": "npm run typecheck -w textsift-core && npm run typecheck -w textsift",
    "test": "bun x playwright test",
    "test:zig": "mise exec -- zig test packages/textsift-core/src/zig/math.zig",
    "format": "bun x prettier --write packages/*/src",
    "format:check": "bun x prettier --check packages/*/src"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.69",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "zod": "3.25.76",
    "@astrojs/sitemap": "3.3.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamchong/textsift.git"
  }
}
