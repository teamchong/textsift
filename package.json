{
  "name": "pii-wasm",
  "version": "0.0.1",
  "description": "PII detection and redaction that runs openai/privacy-filter locally in the browser or Node via WebGPU or WebAssembly. No backend required.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pii",
    "privacy",
    "redaction",
    "webgpu",
    "webassembly",
    "wasm",
    "browser",
    "openai",
    "privacy-filter",
    "token-classification",
    "ner"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run build:zig && npm run build:opt && node scripts/inline-wasm.mjs && bun build src/js/index.ts --outdir dist --target browser --format esm --sourcemap=external && bun x tsc --emitDeclarationOnly",
    "build:zig": "mise exec -- zig build-exe -target wasm32-freestanding -mcpu=generic+simd128+relaxed_simd -O ReleaseFast -fstrip -flto src/zig/wasm_exports.zig -cflags -O3 -mrelaxed-simd -flto -- src/c/fma.c --name pii -fno-entry -rdynamic && mv pii.wasm dist/",
    "build:opt": "wasm-opt -O3 --strip-producers --strip-target-features dist/pii.wasm -o dist/pii.wasm --enable-simd --enable-bulk-memory --enable-nontrapping-float-to-int --enable-sign-ext --enable-mutable-globals --enable-relaxed-simd --inlining-optimizing --always-inline-max-function-size 256 --flexible-inline-max-function-size 512 --inline-functions-with-loops",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun x playwright test",
    "test:zig": "mise exec -- zig test src/zig/math.zig",
    "measure:experts": "python3 scripts/measure-experts.py",
    "format": "bun x prettier --write src/js/",
    "format:check": "bun x prettier --check src/js/"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.69",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamchong/pii-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/teamchong/pii-wasm/issues"
  },
  "homepage": "https://teamchong.github.io/pii-wasm/"
}
